# =====================================================================
# AI Coding Agent Platform — environment contract
# Copy to .env and adjust. .env is gitignored.
# =====================================================================

# ---- General ----
APP_ENV=development            # development | staging | production
APP_NAME=ai-coding-agent
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                # json | console

# ---- API ----
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1                  # use >1 in prod (uvicorn workers)
API_RELOAD=true                # dev only
API_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ---- Security ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256            # HS256 dev, RS256 prod
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=30
PASSWORD_HASH_SCHEME=argon2

# ---- Seed admin (dev convenience) ----
SEED_ADMIN=true
SEED_ADMIN_EMAIL=admin@local.test
SEED_ADMIN_PASSWORD=changeme123!

# ---- Postgres ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=ai_coding_agent
DATABASE_URL=postgresql+asyncpg://app:app@postgres:5432/ai_coding_agent

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# ---- Qdrant (Phase 2+, present from Phase 1 for forward-compat) ----
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=

# ---- LLM providers (Phase 4+; defined here so config is forward-compatible) ----
LLM_PROVIDER=ollama            # ollama | openai | vllm | anthropic
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# ---- GitHub (Phase 6) — PAT with `repo` scope for PR generation + AI review ----
GITHUB_TOKEN=
GITHUB_API_BASE=https://api.github.com

# ---- Embeddings (Phase 2+) ----
EMBEDDING_PROVIDER=local       # local (sentence-transformers) | openai
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ---- Rate limits ----
RATE_LIMIT_ANON_PER_MIN=30
RATE_LIMIT_AUTHED_PER_MIN=300
RATE_LIMIT_AUTH_ENDPOINTS_PER_MIN=10

# ---- Ingestion (Phase 2) ----
INGEST_WORKSPACE_DIR=/var/lib/aca/workspace      # where repos are cloned/expanded inside containers
INGEST_MAX_FILE_BYTES=1048576                    # 1 MiB hard cap per file
INGEST_MAX_REPO_BYTES=536870912                  # 512 MiB hard cap per repo
INGEST_CHUNK_TARGET_TOKENS=400
INGEST_CHUNK_OVERLAP_TOKENS=64
INGEST_EMBED_BATCH_SIZE=32
INGEST_ALLOWED_LANGS=["python","typescript","javascript","go","rust","java","cpp","c","kotlin","csharp","ruby","php","swift","scala","html","css","scss","less","xml","markdown","restructuredtext","json","yaml","toml","sql","bash","dockerfile","make","cmake","text","ini","dotenv"]

# ---- Celery (Phase 2) ----
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ---- Observability (Phase 8) ----
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=ai-coding-agent-api
PROMETHEUS_ENABLED=true

# ---- Frontend (Vite) — prefix VITE_ to expose to client ----
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_BASE_URL=ws://localhost:8000
# Show the Sandbox UI. Local docker-compose has a Docker socket so it works here;
# leave this UNSET on managed PaaS (Render/Vercel) where the sandbox is disabled.
VITE_SANDBOX_ENABLED=true
