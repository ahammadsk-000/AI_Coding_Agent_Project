# Normalize line endings: source files are LF in the repo, regardless of OS.
* text=auto eol=lf

# Explicitly binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  text eol=lf
*.woff binary
*.woff2 binary

# Windows scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
