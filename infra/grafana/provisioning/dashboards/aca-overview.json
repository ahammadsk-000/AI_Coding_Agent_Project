{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "AI Coding Agent — Overview",
  "uid": "aca-overview",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "LLM requests (5m rate)",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(rate(aca_llm_requests_total[5m]))", "legendFormat": "req/s" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "type": "stat",
      "title": "Total tokens",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "sum(aca_llm_tokens_total)", "legendFormat": "tokens" }
      ]
    },
    {
      "type": "stat",
      "title": "Estimated cost (USD)",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(aca_llm_cost_usd_total)", "legendFormat": "usd" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 4 } }
    },
    {
      "type": "stat",
      "title": "Tool calls",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "sum(aca_tool_calls_total)", "legendFormat": "calls" }
      ]
    },
    {
      "type": "timeseries",
      "title": "LLM tokens/s by kind",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum by (kind) (rate(aca_llm_tokens_total[5m]))",
          "legendFormat": "{{kind}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "LLM latency p50/p95 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(aca_llm_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(aca_llm_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "title": "HTTP requests/s by status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum by (status) (rate(aca_http_requests_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP latency p95 by route (s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, path) (rate(aca_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "{{path}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "title": "Search queries/s by mode",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "targets": [
        {
          "expr": "sum by (mode) (rate(aca_search_requests_total[5m]))",
          "legendFormat": "{{mode}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Chat messages/s by role",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "targets": [
        {
          "expr": "sum by (role) (rate(aca_chat_messages_total[5m]))",
          "legendFormat": "{{role}}"
        }
      ]
    }
  ]
}
